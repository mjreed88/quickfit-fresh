{
  "Comment": "QuickFit AI Chat Workflow using z.ai GLM-5.1",
  "StartAt": "ProcessChatMessage",
  "States": {
    "ProcessChatMessage": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:ACCOUNT:function:QuickFitAIChat",
      "ResultPath": "$.chatResult",
      "Next": "SaveConversation"
    },
    "SaveConversation": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:ACCOUNT:function:QuickFitSaveConversation",
      "Parameters": {
        "userId.$": "$.userId",
        "message.$": "$.message",
        "aiResponse.$": "$.chatResult.message",
        "timestamp.$": "$$.Execution.StartTime"
      },
      "End": true
    }
  }
}
